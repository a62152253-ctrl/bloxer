{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "composer install --no-dev --optimize-autoloader",
    "nixpacksVersion": "1.41.0"
  },
  "deploy": {
    "startCommand": "php -S 0.0.0.0:3000 -t public",
    "healthcheckPath": "/"
  },
  "environment": {
    "PHP_VERSION": "8.2",
    "NIXPACKS_PHP_VERSION": "8.2"
  }
}
