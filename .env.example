# Environment Configuration
APP_ENV=development

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=bloxer_db

# Setup Security
BLOXER_SETUP_PASSWORD=changeme123!

# Security Settings
APP_ENV=production
ENABLE_DEBUG=false
LOG_LEVEL=error
RATE_LIMIT_ENABLED=true
CSRF_PROTECTION=true
SESSION_TIMEOUT=3600
SECURE_COOKIES=true
FORCE_HTTPS=true

# File Upload Settings
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,text/html,text/css,application/javascript

# Email Settings (for future implementation)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

# Railway Deployment Settings
RAILWAY_ENVIRONMENT=production
RAILWAY_SERVICE_NAME=web
RAILWAY_PROJECT_NAME=bloxer

# Railway Database (PostgreSQL)
RAILWAY_DB_HOST=${RAILWAY_PRIVATE_DOMAIN}
RAILWAY_DB_USER=${RAILWAY_POSTGRES_USER}
RAILWAY_DB_PASSWORD=${RAILWAY_POSTGRES_PASSWORD}
RAILWAY_DB_NAME=${RAILWAY_POSTGRES_DB}
RAILWAY_DB_PORT=5432

# Override for Railway deployment
DB_HOST=${RAILWAY_DB_HOST}
DB_USER=${RAILWAY_DB_USER}
DB_PASS=${RAILWAY_DB_PASSWORD}
DB_NAME=${RAILWAY_DB_NAME}
DB_PORT=5432
