# Environment Configuration
APP_ENV=development

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=bloxer_db

# Security Settings
ENABLE_DEBUG=true
LOG_LEVEL=debug
RATE_LIMIT_ENABLED=true
CSRF_PROTECTION=true

# File Upload Settings
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,text/html,text/css,application/javascript

# Email Settings (for future implementation)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
